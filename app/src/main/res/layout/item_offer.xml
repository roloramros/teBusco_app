<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Chofer"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark_blue" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.8"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvOfferPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$500 CUP"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/success_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvArrivalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Llega en 10 min"
                    android:textSize="15sp"
                    android:textColor="@color/primary_blue" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <!-- Botón Rechazar (X) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejectOffer"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconTint="@color/white"
                android:backgroundTint="?attr/colorError" />

            <!-- Botón Ver Vehículo (Ojo) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewVehicle"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                app:icon="@android:drawable/ic_menu_view"
                app:strokeColor="@color/primary_blue"
                app:iconTint="@color/primary_blue" />

            <!-- Botón Aceptar (Check) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAcceptOffer"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/checkbox_on_background"
                app:iconTint="@color/white"
                android:backgroundTint="@color/success_green" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
